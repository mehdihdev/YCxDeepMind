{
  "name": "forge-rde",
  "version": "0.1.0",
  "description": "Forge RDE base Electron app scaffold",
  "main": "src/main.js",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./src/renderer/styles.src.css -o ./src/renderer/styles.css",
    "dev": "electron .",
    "dev:css": "npx @tailwindcss/cli -i ./src/renderer/styles.src.css -o ./src/renderer/styles.css --watch",
    "dev:remote": "FORGE_REMOTE_URL=https://solusforge.com electron .",
    "start": "electron .",
    "server": "node src/server/index.mjs",
    "test": "echo \"No tests configured yet\""
  },
  "keywords": [
    "electron",
    "robotics",
    "forge-rde"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.57.2",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "session-file-store": "^1.5.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "electron": "^38.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1"
  }
}
