{
  "robot": {
    "name": "ELEGOO Smart Robot Car V4.0",
    "type": "differential_drive",
    "description": "4-wheel differential drive robot car with ultrasonic and IR sensors"
  },

  "controller": {
    "type": "arduino_uno",
    "board": "Arduino UNO R3",
    "port": "/dev/cu.usbserial-110",
    "baudrate": 115200
  },

  "jetson": {
    "ip": "192.168.1.100",
    "ssh_user": "jetson",
    "ssh_key": "~/.ssh/id_rsa",
    "workspace": "~/forge-elegoo-car"
  },

  "motors": {
    "driver": "TB6612",
    "wheels": {
      "front_left": {
        "enable_pin": 6,
        "direction_pin": 8,
        "standby_pin": 3,
        "encoder": false
      },
      "front_right": {
        "enable_pin": 5,
        "direction_pin": 7,
        "standby_pin": 3,
        "encoder": false
      },
      "rear_left": {
        "enable_pin": 6,
        "direction_pin": 8,
        "standby_pin": 3,
        "encoder": false
      },
      "rear_right": {
        "enable_pin": 5,
        "direction_pin": 7,
        "standby_pin": 3,
        "encoder": false
      }
    },
    "max_speed": 255,
    "min_speed": 50
  },

  "servos": {
    "ultrasonic_pan": {
      "pin": 10,
      "min_angle": 0,
      "max_angle": 180,
      "default_angle": 90,
      "model": "SG90"
    }
  },

  "sensors": {
    "ultrasonic": {
      "type": "HC-SR04",
      "trigger_pin": 13,
      "echo_pin": 12,
      "max_distance_cm": 150
    },
    "ir_line": {
      "type": "TCRT5000",
      "pins": {
        "left": "A2",
        "center": "A1",
        "right": "A0"
      },
      "threshold": 500
    },
    "ir_obstacle": {
      "type": "not_populated_on_default_v4",
      "enabled": false
    }
  },

  "cameras": [
    {
      "id": "fpv",
      "name": "Front Camera",
      "type": "esp32_wrover",
      "device": "",
      "ip": "",
      "stream_port": 81,
      "stream_path": "/stream",
      "resolution": [640, 480],
      "fps": 15,
      "enabled": true
    }
  ],

  "servers": {
    "car": {
      "host": "0.0.0.0",
      "port": 8765,
      "protocol": "websocket"
    },
    "camera": {
      "host": "0.0.0.0",
      "port": 8766,
      "protocol": "websocket"
    }
  },

  "control": {
    "mode": "velocity",
    "update_rate_hz": 50,
    "deadzone": 10,
    "acceleration_limit": 50
  },

  "teleoperation": {
    "enabled": true,
    "input_sources": ["websocket", "ir_remote", "bluetooth"],
    "ir_remote_protocol": "NEC"
  },

  "recording": {
    "fps": 30,
    "format": "lerobot-v2",
    "output_dir": "~/elegoo-datasets",
    "include_sensors": ["ultrasonic", "ir_line", "ir_obstacle"],
    "include_cameras": ["fpv"]
  },

  "mujoco": {
    "model": "./mujoco/elegoo_car.xml",
    "scene": "./mujoco/elegoo_car_scene.xml"
  }
}
