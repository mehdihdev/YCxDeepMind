PORT=3030
APP_URL=http://127.0.0.1:3030
SESSION_SECRET=replace-with-random-secret
SESSION_TTL_DAYS=30
FORGE_REMOTE_URL=

# Supabase project config (required for auth)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Optional alternative to publishable key (server-side use)
# SUPABASE_SECRET_KEY=

# Required for persisted GitHub token hydration (same pattern as forge-server)
SUPABASE_SERVICE_ROLE_KEY=

# Google AI (Nano Banana integration for Artifact Generator)
GOOGLE_AI_API_KEY=
# Default from Google docs for Nano Banana image generation:
NANO_BANANA_MODEL=gemini-3.1-flash-image-preview
# Optional override (normally keep default):
GOOGLE_GENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Local repo resolution for Code Workspace by GitHub repo selector
# Supports either $LOCAL_REPOS_ROOT/<owner>/<repo> or $LOCAL_REPOS_ROOT/<repo>
LOCAL_REPOS_ROOT=
